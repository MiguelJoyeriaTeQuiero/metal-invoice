generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id         String    @id @default(cuid())
  name       String
  taxId      String    @unique
  address    String
  postalCode String
  city       String
  province   String
  country    String    @default("España")
  phone      String?
  email      String?
  notes      String?
  contacts   Contact[]
  invoices   Invoice[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([name])
  @@index([taxId])
}

model Contact {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  role       String?
  phone      String?
  email      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
}

model Invoice {
  id            String        @id @default(cuid())
  number        String        @unique
  type          InvoiceType   @default(STANDARD)
  status        InvoiceStatus @default(PENDING)
  paymentMethod PaymentMethod @default(TRANSFER)
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  originalId    String?
  original      Invoice?      @relation("Rectificativas", fields: [originalId], references: [id])
  rectificativas Invoice[]    @relation("Rectificativas")
  lines         InvoiceLine[]
  subtotal      Decimal       @default(0) @db.Decimal(12, 2)
  totalDiscount Decimal       @default(0) @db.Decimal(12, 2)
  totalIgic     Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @default(0) @db.Decimal(12, 2)
  iban          String?
  observations  String?
  internalNotes String?
  sentAt        DateTime?
  voidedAt      DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([issueDate])
  @@index([number])
}

model InvoiceLine {
  id           String   @id @default(cuid())
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lineOrder    Int      @default(0)
  itemType     ItemType
  metal        Metal
  product      String
  description  String?
  serialNumber String?
  weightGrams  Decimal  @db.Decimal(10, 4)
  purity       Decimal  @db.Decimal(5, 4)
  quantity     Decimal  @db.Decimal(10, 4)
  unitPrice    Decimal  @db.Decimal(12, 2)
  discount     Decimal  @default(0) @db.Decimal(5, 2)
  igicRate     Decimal  @default(0) @db.Decimal(5, 4)
  igicAmount   Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal    Decimal  @default(0) @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([invoiceId])
}

enum InvoiceType {
  STANDARD
  RECTIFICATIVE
}

enum InvoiceStatus {
  PENDING
  PAID
  PARTIAL
  VOIDED
}

enum PaymentMethod {
  TRANSFER
  CARD
}

enum ItemType {
  INGOT
  COIN
}

enum Metal {
  GOLD
  SILVER
}
